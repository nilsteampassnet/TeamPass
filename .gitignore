test.html

# App config — local files, never commit
/app/config/settings.php
/app/config/settings.php.*
/app/config/tp.config*

# CSRF protector — local config and backups
!/app/includes/libraries/csrfp/log
app/includes/libraries/csrfp/libs/csrfp.config.php
app/includes/libraries/csrfp/libs/csrfp.config.php.*

# Master encryption key — never commit the secrets directory content
/secrets/*
!/secrets/.gitkeep

# Storage directories (3.2.0+) — user data must never be committed
/storage/files/*
!/storage/files/.htaccess
!/storage/files/empty_file.txt
/storage/upload/*
!/storage/upload/.htaccess
!/storage/upload/empty_file.txt
/storage/backups/*
!/storage/backups/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/onthefly/*
!/storage/onthefly/.gitkeep

# Avatars are user data — never commit
/public/assets/avatars/*
!/public/assets/avatars/.htaccess
!/public/assets/avatars/empty_file.txt

# Generated/runtime files
/app/includes/tables_integrity.json
EncryptedFile_*

# Local development scripts
/app/scripts/_local/*
/.auto-claude/*
/_tools/*
/_things/*
/_stubs/*
/coverage/*
/workReadmeFiles/*

gcommit.sh
gdev.sh
gpush.sh
gitdo.sh
version-commit.php
tp_minor_release.txt
phpinsights.php
/.vscode/*

# PHP test artifacts
.phpunit.result.cache
.phpunit.cache/
tests/_output/
tests/_support/_generated/

# Snyk Security Extension - AI Rules (auto-generated)
.github/instructions/snyk_rules.instructions.md

*debug*.php
.venv/
mempalace.yaml
entities.json
*:Zone.Identifier
