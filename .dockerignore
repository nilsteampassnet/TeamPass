# ============================================
# TeamPass Docker Ignore File
# ============================================

# Git
.git
.gitignore
.gitattributes
.github

# Docker files (except what we need)
.dockerignore
.dockerignore.new
Dockerfile.old
.dcignore
docker-compose*.yml

# Documentation (except important ones)
*.md
!README.md
docs/
CHANGELOG*

# Development
.vscode
.idea
.DS_Store
*.swp
*.swo
*~
.editorconfig

# Tests
tests/
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache

# CI/CD
.scrutinizer.yml
.codacy.yml
.travis.yml
.gitlab-ci.yml
.eslintrc
.eslintignore

# Logs and temporary files
*.log
logs/
tmp/
temp/
cache/

# CSRF logs (will be created at runtime)
app/includes/libraries/csrfp/log/*
!app/includes/libraries/csrfp/log/.gitkeep

# User data (will be in volumes)
storage/files/*
!storage/files/.gitkeep
storage/upload/*
!storage/upload/.gitkeep
storage/sk/*
!storage/sk/.gitkeep
storage/config/*
!storage/config/.gitkeep

# Install state — generated at runtime and persisted on volumes, never baked
# into the image (issue #5236). A stray local copy would shadow the runtime
# symlink or, for the master key, leak a development secret.
app/config/settings.php
app/config/settings.php.*
app/includes/libraries/csrfp/libs/csrfp.config.php
app/includes/libraries/csrfp/libs/csrfp.config.php.*
secrets/*
!secrets/.gitkeep

# Backups
backups/
*.bak
*.backup
*.sql
*.zip
*.tar.gz

# Node modules (not needed in container)
node_modules/
package-lock.json
.npm

# Vendor (will be copied from builder stage)
# Don't ignore vendor/ as we copy it from composer stage

# OS files
Thumbs.db
desktop.ini

# Old docker files
teampass-docker-start.sh
